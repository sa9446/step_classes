public class HelloApp {
    public static void main(String[] args) {
        // Check if a command-line argument is provided, default to "World" if not
        String name;
        if (args.length > 0) {
            name = args[0];
        } else {
            name = "World";
        }
        System.out.println("Hello, " + name + "!");
    }
}
