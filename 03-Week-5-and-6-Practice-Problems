    public static void topic8_level2_problem2() {
        System.out.println("=== Topic 8 | Level 2 | Problem 2: Matrix Addition ===");
 
        int[][] matrixA = {
            {1, 2, 3},
            {4, 5, 6}
        };
 
        int[][] matrixB = {
            {7, 8, 9},
            {10, 11, 12}
        };
 
        int rows = matrixA.length;
        int cols = matrixA[0].length;
        int[][] resultMatrix = new int[rows][cols];
 
        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
