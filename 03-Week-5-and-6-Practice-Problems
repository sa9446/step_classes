            {10, 20, 30},
            {40, 50, 60},
            {70, 80, 90}
        };
 
        int rows = matrix.length;
        int cols = matrix[0].length;
 
        int[] rowSums = new int[rows];
        int[] colSums = new int[cols];
 
        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                rowSums[i] += matrix[i][j];
                colSums[j] += matrix[i][j];
            }
        }
 
        System.out.println("Matrix with Row and Column Sums:");
        System.out.printf("  %8s", "");
        for (int j = 0; j < cols; j++) {
            System.out.printf("Col%-5d", j);
        }
        System.out.println("| Row Sum");
 
        for (int i = 0; i < rows; i++) {
            System.out.printf("  Row %-2d ", i);
            for (int j = 0; j < cols; j++) {
                System.out.printf("%-8d", matrix[i][j]);
            }
            System.out.println("| " + rowSums[i]);
        }
 
        System.out.printf("  %-8s", "Col Sum:");
        for (int j = 0; j < cols; j++) {
            System.out.printf("%-8d", colSums[j]);
        }
        System.out.println();
        System.out.println();
    }
 
    public static void topic10_level1_problem1() {
        System.out.println("=== Topic 10 | Level 1 | Problem 1: System.err and System.exit ===");
 
        Scanner scanner = new Scanner(System.in);
        String[] fruits = {"Apple", "Banana", "Cherry", "Date", "Elderberry"};
 
        System.out.println("Available Fruits:");
        for (int i = 0; i < fruits.length; i++) {
            System.out.println("  [" + i + "] " + fruits[i]);
        }
 
        System.out.print("Enter index to select a fruit (0-" + (fruits.length - 1) + "): ");
 
        if (!scanner.hasNextInt()) {
            System.err.println("Error: Input must be a valid integer.");
            System.exit(1);
        }
 
        int selectedIndex = scanner.nextInt();
 
        if (selectedIndex < 0 || selectedIndex >= fruits.length) {
            System.err.println("Error: Index " + selectedIndex + " is out of bounds.");
            System.err.println("Valid range: 0 to " + (fruits.length - 1));
            System.exit(2);
        }
 
        String selectedFruit = fruits[selectedIndex];
        System.out.println("You selected: " + selectedFruit);
        System.out.println();
    }
 
    public static void topic10_level1_problem2() {
        System.out.println("=== Topic 10 | Level 1 | Problem 2: Multiple Validation Checks ===");
 
        Scanner scanner = new Scanner(System.in);
 
        int maxStudents = 10;
        int minPassingScore = 0;
        int maxPassingScore = 100;
 
        System.out.print("Enter number of students (1-" + maxStudents + "): ");
 
        if (!scanner.hasNextInt()) {
            System.err.println("Error: Please enter a valid integer.");
            System.exit(1);
        }
 
        int studentCount = scanner.nextInt();
 
        if (studentCount <= 0 || studentCount > maxStudents) {
            System.err.println("Error: Student count must be between 1 and " + maxStudents + ".");
            System.exit(2);
        }
 
        int[] scores = new int[studentCount];
 
        for (int i = 0; i < scores.length; i++) {
            System.out.print("  Enter score for student " + (i + 1) + " (" + minPassingScore + "-" + maxPassingScore + "): ");
 
            if (!scanner.hasNextInt()) {
                System.err.println("Error: Score must be a valid integer.");
                System.exit(3);
            }
 
            scores[i] = scanner.nextInt();
 
            if (scores[i] < minPassingScore || scores[i] > maxPassingScore) {
                System.err.println("Error: Score " + scores[i] + " is out of valid range (" + minPassingScore + "-" + maxPassingScore + ").");
                System.exit(4);
            }
        }
 
        System.out.println("All scores validated successfully!");
        System.out.println("Scores entered:");
        for (int i = 0; i < scores.length; i++) {
            System.out.println("  Student " + (i + 1) + ": " + scores[i]);
        }
 
        System.out.println("Program completed successfully (Exit code: 0).");
        System.out.println();
    }
 
    public static void topic10_level1_problem3() {
        System.out.println("=== Topic 10 | Level 1 | Problem 3: Exit Codes for Error Types ===");
 
        Scanner scanner = new Scanner(System.in);
        String[] validOperations = {"ADD", "REMOVE", "VIEW", "EXIT"};
 
        System.out.println("Available Operations:");
        for (int i = 0; i < validOperations.length; i++) {
            System.out.println("  " + (i + 1) + ". " + validOperations[i]);
        }
 
        System.out.print("Enter operation number (1-" + validOperations.length + "): ");
 
        if (!scanner.hasNextInt()) {
            System.err.println("FATAL: Input is not a number. Exit code: 100");
            System.exit(100);
        }
 
        int operationNumber = scanner.nextInt();
 
        if (operationNumber < 1 || operationNumber > validOperations.length) {
            System.err.println("FATAL: Operation " + operationNumber + " does not exist. Exit code: 101");
            System.exit(101);
        }
 
        String selectedOperation = validOperations[operationNumber - 1];
 
        if (selectedOperation.equals("EXIT")) {
            System.out.println("User requested exit. Terminating gracefully.");
            System.exit(0);
        }
 
        System.out.println("Selected operation: " + selectedOperation);
        System.out.println("Operation executed successfully.");
        System.out.println();
    }
 
