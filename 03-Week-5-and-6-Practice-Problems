    public static void topic8_level3_problem1() {
        System.out.println("=== Topic 8 | Level 3 | Problem 1: Matrix Transpose ===");
 
        int[][] originalMatrix = {
            {1, 2, 3},
            {4, 5, 6}
        };
 
        int originalRows = originalMatrix.length;
        int originalCols = originalMatrix[0].length;
        int[][] transposedMatrix = new int[originalCols][originalRows];
 
        for (int i = 0; i < originalRows; i++) {
            for (int j = 0; j < originalCols; j++) {
                transposedMatrix[j][i] = originalMatrix[i][j];
            }
        }
 
        System.out.println("Original (" + originalRows + "x" + originalCols + "):");
        for (int i = 0; i < originalMatrix.length; i++) {
            System.out.print("  ");
            for (int j = 0; j < originalMatrix[i].length; j++) {
                System.out.printf("%4d", originalMatrix[i][j]);
            }
            System.out.println();
        }
 
        System.out.println("Transposed (" + originalCols + "x" + originalRows + "):");
        for (int i = 0; i < transposedMatrix.length; i++) {
            System.out.print("  ");
            for (int j = 0; j < transposedMatrix[i].length; j++) {
                System.out.printf("%4d", transposedMatrix[i][j]);
            }
            System.out.println();
        }
        System.out.println();
    }
 
    public static void topic9_level2_problem1() {
