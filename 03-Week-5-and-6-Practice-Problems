    public static void topic9_level2_problem2() {
        System.out.println("=== Topic 9 | Level 2 | Problem 2: Find Max/Min in 2D Array ===");
 
        int[][] data = {
            {34, 72, 13, 89},
            {56, 12, 90, 45},
            {67, 23, 78, 41}
        };
 
        int maxValue = data[0][0];
        int minValue = data[0][0];
        int maxRow = 0, maxCol = 0;
        int minRow = 0, minCol = 0;
 
        for (int i = 0; i < data.length; i++) {
            for (int j = 0; j < data[i].length; j++) {
                if (data[i][j] > maxValue) {
                    maxValue = data[i][j];
                    maxRow = i;
                    maxCol = j;
                }
                if (data[i][j] < minValue) {
                    minValue = data[i][j];
                    minRow = i;
                    minCol = j;
                }
            }
        }
 
        System.out.println("2D Array:");
        for (int i = 0; i < data.length; i++) {
            System.out.print("  ");
            for (int j = 0; j < data[i].length; j++) {
                System.out.printf("%5d", data[i][j]);
            }
            System.out.println();
        }
 
        System.out.println("Maximum: " + maxValue + " at position [" + maxRow + "][" + maxCol + "]");
        System.out.println("Minimum: " + minValue + " at position [" + minRow + "][" + minCol + "]");
        System.out.println();
    }
 
